{
  "contract.seller_name": {
    "keyword": "売主",
    "direction": "right",
    "alternateKeywords": ["売渡人", "譲渡人"]
  },
  "contract.seller_address": {
    "keyword": "売主",
    "direction": "below",
    "alternateKeywords": ["売渡人"]
  },
  "contract.buyer_name": {
    "keyword": "買主",
    "direction": "right",
    "alternateKeywords": ["買受人", "譲受人"]
